{
  "name": "hk-recorder",
  "version": "1.0.0",
  "description": "Headless screen recording engine (Electron desktopCapturer + MediaRecorder, chunked segments, ffmpeg stitching)",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "test-record": "electron . --test-record",
    "test-mark": "electron . --test-mark --ozone-platform=x11 --disable-features=WebRTCPipeWireCapturer"
  },
  "license": "MIT",
  "dependencies": {
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "electron": "^31.3.1"
  }
}
